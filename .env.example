# ---- Supabase ----
# Project URL and anon key (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key — SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- App ----
# Public base URL of the deployed app (used for OAuth redirect).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Comma-separated emails auto-promoted to admin on first login (bootstrap).
ADMIN_EMAILS=owner@example.com

# ---- Stripe (Phase 4 checkout) ----
# Secret key (server). Test mode: sk_test_...
STRIPE_SECRET_KEY=sk_test_your-secret-key
# Webhook signing secret from `stripe listen` or the dashboard endpoint.
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# Optional publishable key (pk_test_...). Hosted Checkout does not require it.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
