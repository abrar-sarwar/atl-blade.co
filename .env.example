# ---- Supabase ----
# Project URL and anon key (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key — SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- App ----
# Public base URL of the deployed app (used for OAuth redirect).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Comma-separated emails auto-promoted to admin on first login (bootstrap).
ADMIN_EMAILS=owner@example.com
